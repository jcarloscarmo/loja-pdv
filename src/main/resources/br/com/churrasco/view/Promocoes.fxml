<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.churrasco.controller.PromocoesController"
            prefHeight="700.0" prefWidth="1200.0">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Button text="VOLTAR" onAction="#voltarMenu" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label text="GESTÃO DE PROMOÇÕES" textFill="WHITE">
                <font><Font name="System Bold" size="20.0"/></font>
            </Label>
        </HBox>
    </top>

    <left>
        <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #ecf0f1;" prefWidth="360">
            <Label text="Cadastro da Promoção" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

            <Label text="Nome da promoção"/>
            <TextField fx:id="txtNomePromocao" promptText="Ex: 2 Maioneses por 15"/>

            <Label text="Preço final do combo (R$)"/>
            <TextField fx:id="txtPrecoCombo" promptText="0,00"/>

            <HBox spacing="10">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Início"/>
                    <DatePicker fx:id="dtInicio" maxWidth="Infinity"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Fim"/>
                    <DatePicker fx:id="dtFim" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <CheckBox fx:id="chkAtiva" text="Promoção ativa" selected="true"/>

            <Separator/>
            <Label text="Resumo do combo" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblResumoCombo" text="Nenhum item no combo" wrapText="true"
                   style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #d5dbdb; -fx-border-radius: 5;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="10">
                <Button text="LIMPAR" onAction="#limparFormulario" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button text="SALVAR PROMOÇÃO" onAction="#salvarPromocao" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

            <Button text="EXCLUIR SELECIONADA" onAction="#excluirPromocao" maxWidth="Infinity"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: white;">
            <Label text="Produtos elegíveis (somente UN)" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscaProdutos" promptText="Buscar por nome ou código" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtQuantidadeItem" promptText="Qtd" prefWidth="70" text="1"/>
                <Button text="ADICIONAR AO COMBO" onAction="#adicionarProdutoAoCombo"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

            <SplitPane dividerPositions="0.55">
                <TableView fx:id="tabelaProdutos">
                    <columns>
                        <TableColumn fx:id="colProdutoCodigo" text="Cód" prefWidth="80"/>
                        <TableColumn fx:id="colProdutoNome" text="Produto" prefWidth="260"/>
                        <TableColumn fx:id="colProdutoUnidade" text="Un." prefWidth="60"/>
                        <TableColumn fx:id="colProdutoPreco" text="Preço" prefWidth="100"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>

                <VBox spacing="10">
                    <Label text="Itens do combo" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tabelaItensCombo" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colItemCodigo" text="Cód" prefWidth="70"/>
                            <TableColumn fx:id="colItemNome" text="Produto" prefWidth="200"/>
                            <TableColumn fx:id="colItemQuantidade" text="Qtd" prefWidth="60"/>
                            <TableColumn fx:id="colItemPrecoBase" text="Preço Base" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                    <Button text="REMOVER ITEM DO COMBO" onAction="#removerItemDoCombo" maxWidth="Infinity"
                            style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </SplitPane>

            <Separator/>
            <Label text="Promoções cadastradas" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TableView fx:id="tabelaPromocoes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPromocaoNome" text="Nome" prefWidth="240"/>
                    <TableColumn fx:id="colPromocaoPreco" text="Preço Combo" prefWidth="120"/>
                    <TableColumn fx:id="colPromocaoInicio" text="Início" prefWidth="110"/>
                    <TableColumn fx:id="colPromocaoFim" text="Fim" prefWidth="110"/>
                    <TableColumn fx:id="colPromocaoStatus" text="Status" prefWidth="80"/>
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
        </VBox>
    </center>

</BorderPane>
